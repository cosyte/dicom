{
  "name": "@cosyte/dicom",
  "version": "0.0.1",
  "description": "Developer-focused DICOM Part 10 parser + utility library for Node.js and TypeScript — metadata-first, vendor-quirky-tolerant, dual ESM/CJS.",
  "keywords": [
    "dicom",
    "parser",
    "medical-imaging",
    "healthcare",
    "interoperability",
    "typescript",
    "part-10",
    "metadata"
  ],
  "homepage": "https://github.com/cosyte/dicom#readme",
  "bugs": {
    "url": "https://github.com/cosyte/dicom/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosyte/dicom.git"
  },
  "license": "MIT",
  "author": "Cosyte <hello@cosyte.com> (https://cosyte.com)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "esbuild@>=0.27.3 <0.28.1": "0.28.1",
      "js-yaml@>=4.0.0 <4.2.0": "4.2.0"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "TRADEMARKS.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prettier": "@cosyte/prettier-config",
  "scripts": {
    "build": "tsup",
    "changeset": "changeset",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:exports": "attw --pack . --profile node16",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\" --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.{ts,md}\" \"scripts/**/*.ts\" \"test/**/*.ts\" \"*.{json,md,yml,yaml}\" --no-error-on-unmatched-pattern",
    "format:check": "prettier --check \"src/**/*.{ts,md}\" \"scripts/**/*.ts\" \"test/**/*.ts\" \"*.{json,md,yml,yaml}\" --no-error-on-unmatched-pattern",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gen:dictionary": "tsx scripts/generate-dictionary.ts",
    "gen:annex-e": "tsx scripts/generate-annex-e.ts",
    "gen:all": "pnpm gen:dictionary && pnpm gen:annex-e",
    "phi-scan": "tsx scripts/phi-scan.ts",
    "smoke": "tsx scripts/smoke.ts",
    "pack:docs": "bash scripts/build-docs-artifacts.sh",
    "attw": "attw --pack .",
    "version": "changeset version && node scripts/sync-version.mjs && prettier --write package.json src/version.ts",
    "release": "changeset publish",
    "prepublishOnly": "pnpm clean && pnpm gen:all && pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm attw",
    "prepare": "command -v simple-git-hooks >/dev/null 2>&1 && simple-git-hooks || true"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@changesets/cli": "2.31.0",
    "@cosyte/eslint-config": "^0.0.3",
    "@cosyte/prettier-config": "^0.0.2",
    "@cosyte/tsconfig": "^0.0.2",
    "@cosyte/test-utils": "^0.0.1",
    "@cosyte/tsup-config": "^0.0.1",
    "@cosyte/vitest-config": "^0.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.5.0",
    "fast-check": "3.23.2",
    "prettier": "3.8.3",
    "simple-git-hooks": "2.13.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.4"
  },
  "dependencies": {},
  "simple-git-hooks": {
    "pre-commit": "pnpm phi-scan --staged"
  }
}
